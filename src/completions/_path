#compdef path

_path() {
    local -a commands
    commands=(
        'read:Load all paths from config files into PATH'
        'add:Add path(s) to a group'
        'remove:Remove a path from a group'
        'clean:Remove nonexistent paths from groups'
        'list:Show all paths in current PATH'
        'find:Find executables matching pattern'
        'groups:List available groups'
        'dir:Show path config directory'
        'help:Show usage'
    )

    _arguments -C \
        '1:command:->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'path command' commands
            ;;
        args)
            case $words[1] in
                add)
                    if [[ "$words[2]" == "--group" && $CURRENT -eq 3 ]]; then
                        local -a groups
                        local path_dir="$HOME/.paths"
                        [[ -d "$path_dir" ]] && groups=(${(f)"$(ls "$path_dir" 2>/dev/null)"})
                        _describe -t groups 'group' groups
                    else
                        _arguments '--group[Specify group]:group:' '*:path:_files -/'
                    fi
                    ;;
                remove)
                    _files -/
                    ;;
            esac
            ;;
    esac
}

_path "$@"
