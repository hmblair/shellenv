#!/usr/bin/env zsh

# path - PATH Management CLI
# Manages PATH environment variable through organized group files

SCRIPT_DIR="${0:A:h}"
source "$SCRIPT_DIR/../common"

# Configuration
PATH_DIR="$HOME/.paths"

# ─────────────────────────────────────────────────────────────────────────────
# Helper functions
# ─────────────────────────────────────────────────────────────────────────────

usage() {
    echo "Usage: path <command> [options]"
    echo ""
    echo "Commands:"
    echo "  read                  Output export statement (use with eval)"
    echo "  add <path>...         Add path(s) to a group"
    echo "  remove [path]         Remove a path from a group"
    echo "  clean                 Remove nonexistent paths from groups"
    echo "  list                  Show all paths in current PATH"
    echo "  find <pattern>        Find executables matching pattern"
    echo "  dir                   Show path config directory"
    echo ""
    echo "Add to .zshrc:"
    echo "  eval \"\$(path read)\""
    echo ""
    echo "Examples:"
    echo "  path add ~/bin"
    echo "  path remove"
    echo "  path list"
}

# Get system paths (macOS and Linux)
system_paths() {
    # macOS: /etc/paths and /etc/paths.d/*
    /bin/cat /etc/paths /etc/paths.d/*(N) 2>/dev/null

    # Linux: parse PATH from /etc/environment
    if [[ -f /etc/environment ]]; then
        /usr/bin/grep '^PATH=' /etc/environment 2>/dev/null | /usr/bin/sed 's/^PATH="//;s/"$//' | /usr/bin/tr ':' '\n'
    fi
}

# Check if string contains line
contains() {
    echo "$1" | /usr/bin/grep -Fxq "$2"
}

# Convert PATH to file format (one per line)
path_to_file() {
    echo "$PATH" | /usr/bin/tr ':' '\n' | /usr/bin/grep -v '^$'
}

# Convert file format to PATH
file_to_path() {
    [[ $# -eq 0 ]] && return
    local paths=()
    while read -r line; do
        paths+=("${line/#\~/$HOME}")
    done < <(/bin/cat "$@")
    echo "$(IFS=':'; echo "${paths[*]}")"
}

# ─────────────────────────────────────────────────────────────────────────────
# Commands
# ─────────────────────────────────────────────────────────────────────────────

cmd_read() {
    /bin/mkdir -p "$PATH_DIR"
    # Output export statement to be eval'd: eval "$(path read)"
    echo "export PATH=\"$(file_to_path "$PATH_DIR"/*(N)):\$PATH\""
}

cmd_add() {
    if [[ $# -eq 0 ]]; then
        error "No path to add."
    fi

    /bin/mkdir -p "$PATH_DIR"

    for p in "$@"; do
        local resolved="${p:A}"
        if [[ -z "$resolved" ]]; then
            echo "${RED}Error:${NC} '$p' does not exist or is invalid"
            continue
        fi

        # Reject paths with newlines (would corrupt file format)
        if [[ "$resolved" == *$'\n'* ]]; then
            echo "${RED}Error:${NC} Path cannot contain newlines"
            continue
        fi

        echo "Select a group for '$resolved':"
        local groups=("$PATH_DIR"/*(N))
        local group_names=()
        for g in "${groups[@]}"; do
            [[ -f "$g" ]] && group_names+=("${g:t}")
        done
        group_names+=("Create new group")

        menu "${group_names[@]}"
        local idx=$(($? + 1))
        echo ""

        local group
        if [[ $idx -eq ${#group_names[@]} ]]; then
            # Create new group
            printf "Group name: "
            read -r new_name
            if [[ -z "$new_name" ]]; then
                echo "${RED}Error:${NC} Group name cannot be empty"
                continue
            fi
            group="$PATH_DIR/$new_name"
            touch "$group"
            echo "${GREEN}Created group '$new_name'${NC}"
        else
            group="${groups[$idx]}"
        fi

        if /usr/bin/grep -Fxq "$resolved" "$group" 2>/dev/null; then
            echo "${YELLOW}Warning:${NC} $resolved is already in ${group:t}"
        else
            echo "$resolved" >> "$group"
            success "Added $resolved to ${group:t}"
        fi
    done
}

cmd_remove() {
    /bin/mkdir -p "$PATH_DIR"

    local groups=("$PATH_DIR"/*)
    if [[ ${#groups[@]} -eq 0 ]] || [[ ! -e "${groups[1]}" ]]; then
        error "No path groups found."
    fi

    # If a path was provided as argument, find and remove it
    if [[ -n "$1" ]]; then
        local target="${1:A}"
        [[ -z "$target" ]] && target="$1"

        for group in "${groups[@]}"; do
            if /usr/bin/grep -Fxq "$target" "$group" 2>/dev/null; then
                local temp=$(/usr/bin/mktemp)
                /usr/bin/grep -Fxv "$target" "$group" > "$temp"
                /bin/mv "$temp" "$group"
                success "Removed $target from ${group:t}"
                return
            fi
        done
        error "'$target' not found in any group."
    fi

    # Interactive mode: select group, then select path
    echo "Select a group:"
    menu "${groups[@]:t}"
    local group="${groups[$(($? + 1))]}"
    echo ""

    if [[ ! -s "$group" ]]; then
        error "Group '${group:t}' is empty."
    fi

    local paths=()
    while IFS= read -r line; do
        [[ -n "$line" ]] && paths+=("$line")
    done < "$group"

    if [[ ${#paths[@]} -eq 0 ]]; then
        error "Group '${group:t}' has no paths."
    fi

    echo "Select a path to remove from '${group:t}':"
    menu "${paths[@]}"
    local idx=$(($? + 1))
    local selected="${paths[$idx]}"
    echo ""

    local temp=$(/usr/bin/mktemp)
    /usr/bin/grep -Fxv "$selected" "$group" > "$temp"
    /bin/mv "$temp" "$group"
    success "Removed $selected from ${group:t}"
}

cmd_list() {
    local sys="$(system_paths)"

    # Build path -> group lookup (store both raw and resolved paths)
    typeset -A groups
    for group in "$PATH_DIR"/*; do
        [[ ! -f "$group" ]] && continue
        while IFS= read -r p; do
            [[ -n "$p" ]] && groups[$p]="${group:t}"
        done < "$group"
    done

    path_to_file | while read -r p; do
        local full="${p:A}"
        local display=""
        local symlink_target=""

        # Check if path is a symlink
        if [[ -L "$p" ]]; then
            symlink_target="$full"
            display="$p"
        elif [[ -d "$full" ]]; then
            display="$full"
        else
            display="${ST}$p${NST}"
        fi

        # Check group membership (try both raw path and resolved path)
        local group_name="${groups[$p]}"
        [[ -z "$group_name" && "$full" != "$p" ]] && group_name="${groups[$full]}"

        if [[ -n "$group_name" ]]; then
            icon="${GREEN}󱋻${NC}"
            suffix=" ${GREY}(${group_name})${NC}"
        elif contains "$sys" "$p"; then
            icon="${YELLOW}󰼆${NC}"
            suffix=""
        else
            icon="${RED}󰼈${NC}"
            suffix=""
        fi

        if [[ -n "$symlink_target" ]]; then
            echo -e "${icon} ${display}${suffix} ${CYAN}→ ${symlink_target}${NC}"
        else
            echo -e "${icon} ${display}${suffix}"
        fi
    done
}

cmd_dir() {
    echo "$PATH_DIR"
}

cmd_find() {
    if [[ $# -eq 0 ]]; then
        error "Usage: path find <pattern>"
    fi

    local pattern="$1"
    local results=()

    while read -r dir; do
        [[ ! -d "$dir" ]] && continue
        for f in "$dir"/$~pattern(N); do
            [[ -x "$f" && ! -d "$f" ]] && results+=("$f")
        done
    done < <(path_to_file)

    if [[ ${#results[@]} -eq 0 ]]; then
        echo "${RED}Error:${NC} No match for '$pattern'" >&2
        return 1
    fi

    printf '%s\n' "${results[@]}"
}

cmd_clean() {
    /bin/mkdir -p "$PATH_DIR"

    local groups=("$PATH_DIR"/*)
    if [[ ${#groups[@]} -eq 0 ]] || [[ ! -e "${groups[1]}" ]]; then
        echo "No path groups found."
        return
    fi

    local removed=0
    for group in "${groups[@]}"; do
        [[ ! -f "$group" ]] && continue

        local temp=$(/usr/bin/mktemp)
        local group_removed=0

        while IFS= read -r p; do
            if [[ -z "$p" ]]; then
                continue
            elif [[ -d "$p" ]]; then
                echo "$p" >> "$temp"
            else
                echo "${RED}✕${NC} $p ${GREY}(${group:t})${NC}"
                ((group_removed++))
                ((removed++))
            fi
        done < "$group"

        if [[ $group_removed -gt 0 ]]; then
            /bin/mv "$temp" "$group"
        else
            /bin/rm "$temp"
        fi
    done

    if [[ $removed -eq 0 ]]; then
        echo "${YELLOW}All managed paths exist.${NC}"
    else
        echo ""
        success "Removed $removed nonexistent path(s)."
    fi
}

# ─────────────────────────────────────────────────────────────────────────────
# Main
# ─────────────────────────────────────────────────────────────────────────────

case "${1:-}" in
    read)
        cmd_read
        ;;
    add)
        shift
        cmd_add "$@"
        ;;
    remove)
        shift
        cmd_remove "$@"
        ;;
    clean)
        cmd_clean
        ;;
    list)
        cmd_list
        ;;
    find)
        shift
        cmd_find "$@"
        ;;
    dir)
        cmd_dir
        ;;
    help|--help|-h)
        usage
        ;;
    "")
        usage
        ;;
    *)
        error "Unknown command: $1. Run 'path help' for usage."
        ;;
esac
